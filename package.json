{
  "name": "website-outreach-engine",
  "version": "1.0.0",
  "description": "Local business website opportunity scanner",
  "type": "module",
  "scripts": {
    "server": "node src/server.js",
    "worker": "node src/opportunity-engine/worker.js",
    "build": "node -e \"require('fs').mkdirSync('dist', { recursive: true }); console.log('No frontend build step configured');\"",
    "start": "node src/server.js",
    "snapshot:outreach": "node scripts/screenshot-outreach-websites.js",
    "snapshot:backfill-metadata": "node scripts/screenshot-outreach-websites.js --metadata-only",
    "brief:sales": "node scripts/generate-sales-briefs.js",
    "call:analyze": "python scripts/analyze_call_recording.py",
    "angles:reanalyze": "node scripts/reanalyze-all-businesses.js --wait",
    "blob:seed": "node scripts/seed-blob-data.js",
    "blob:seed-twilio": "node scripts/seed-twilio-settings.js",
    "website:pack": "node scripts/run-single-website.js",
    "website:find-leads": "node scripts/website-find-leads.js",
    "pw:find-leads": "node scripts/pw-find-leads.js",
    "migrate:schema": "node scripts/migrate-legacy-to-schema.js --write",
    "migrate:schema:dry": "node scripts/migrate-legacy-to-schema.js",
    "validate:dual-read": "node scripts/run-dual-read-validation.js",
    "validate:schema-outcome-writes": "node scripts/validate-schema-outcome-writes.js",
    "validate:id-bridge-without-map": "node scripts/validate-id-bridge-without-map.js",
    "validate:schema-production-mode": "node scripts/validate-schema-production-mode.js",
    "verify:production-schema": "node scripts/verify-production-schema-effect.js",
    "server:schema-production": "node scripts/run-schema-production-server.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@vercel/blob": "^2.4.1",
    "cookie-parser": "^1.4.7",
    "express": "^5.2.1",
    "pg": "^8.21.0",
    "playwright": "^1.52.0",
    "stripe": "^22.2.0",
    "twilio": "^6.0.2"
  }
}
