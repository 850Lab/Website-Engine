# OpenAI API key for prepare-assets / generate-ai-assets (DALL·E 3 concept fallback images)
# Copy to .env in project root (loaded automatically by prepare-assets)
OPENAI_API_KEY=sk-your-key-here

# Vercel public preview deployment provider
VERCEL_TOKEN=vercel-token-here
# Optional: route deployments through a Vercel team
VERCEL_TEAM_ID=
# Optional: server-only bypass for Vercel Deployment Protection during automated verification
VERCEL_AUTOMATION_BYPASS_SECRET=

# Stripe billing provider
STRIPE_SECRET_KEY=sk_live_or_test_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_PRICE_ACTIVATION=price_activation_150
STRIPE_PRICE_MAINTENANCE_50=price_maintenance_50
# V7 launch funnel — one-time $1,000 project checkout
STRIPE_PRICE_LAUNCH_1000=price_launch_1000
# Public URL for preview/launch/dashboard links and Twilio Voice webhooks
# Production example: https://pivotalwebsites.com
# Local testing with ngrok: https://your-subdomain.ngrok-free.app
PUBLIC_BASE_URL=

# Future outreach/reply provider layer
# Current code uses manual_simulated outreach and placeholder reply ingestion.
# Use these names for the first real email provider implementation.
OUTREACH_PROVIDER=manual_simulated
OUTREACH_FROM_EMAIL=
RESEND_API_KEY=

# Twilio Voice (click-to-call + recording — no SMS / A2P required)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
FOUNDER_PHONE=

# Twilio SMS provider (future — not used by Voice V1)
TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Keep false until A2P approval is complete and a controlled live send test is planned.
ALLOW_REAL_SMS_SEND=false

# Admin password fallback (used only if no admin account exists)
ADMIN_PASSWORD=change-me

# Distributed campaigns / workers (optional; if omitted, JSON file store is used)
DATABASE_URL=
PG_POOL_MAX=10
WORKER_API_KEY=replace-with-strong-worker-key
# Optional multi-key format for server validation:
# WORKER_API_KEYS=worker-key-1,worker-key-2
WORKER_ID=
WORKER_LEASE_SECONDS=180
WORKER_HEARTBEAT_SECONDS=60
WORKER_IDLE_MS=5000
CAMPAIGN_ID=

# Stage 1 website scoring (optional — without this, performance uses estimated fallback)
GOOGLE_PAGESPEED_API_KEY=

# Vercel Blob — required on production so Sales Mode outcomes/notes persist
# Create a Blob store in Vercel → Storage → Connect → copy BLOB_READ_WRITE_TOKEN
BLOB_READ_WRITE_TOKEN=
